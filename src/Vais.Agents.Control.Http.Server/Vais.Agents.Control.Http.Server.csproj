<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Control.Http</RootNamespace>
    <AssemblyName>Vais.Agents.Control.Http.Server</AssemblyName>
    <Description>ASP.NET Core minimal-API surface for the Vais.Agents control plane. Maps the seven universal IAgentLifecycleManager verbs to REST endpoints under /v1; emits RFC 7807 Problem Details on errors.</Description>
    <PackageTags>agents;ai;llm;control-plane;http;aspnetcore</PackageTags>
    <!-- IDE0005 reports the Microsoft.AspNetCore.Builder using as unnecessary even though
         MapGroup / MapPost / MapGet call sites rely on the extension methods from there.
         Either the analyzer tracks the using incorrectly or the FrameworkReference indirection
         hides the binding. Suppress locally. -->
    <NoWarn>$(NoWarn);IDE0005</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Core\Vais.Agents.Core.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Manifests.Json\Vais.Agents.Control.Manifests.Json.csproj" />
    <ProjectReference Include="..\Vais.Agents.Runtime.Plugins\Vais.Agents.Runtime.Plugins.csproj" />
    <ProjectReference Include="..\Vais.Agents.Runtime.Plugins.Python\Vais.Agents.Runtime.Plugins.Python.csproj" />
    <ProjectReference Include="..\Vais.Agents.Observability.RunStore\Vais.Agents.Observability.RunStore.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Control.Kubernetes.Host</RootNamespace>
    <AssemblyName>Vais.Agents.Control.KubernetesOperator.Host</AssemblyName>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>

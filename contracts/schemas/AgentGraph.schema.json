{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vais.agents AgentGraph manifest",
  "type": "object",
  "properties": {
    "apiVersion": {
      "const": "vais.agents/v1"
    },
    "kind": {
      "const": "AgentGraph"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "properties": {
        "entry": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "ref": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "runtimeUrl": {
                    "type": "string"
                  },
                  "a2aUrl": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "handlerRef": {
                "type": "object",
                "properties": {
                  "typeName": {
                    "type": "string"
                  },
                  "assemblyName": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "stateBindings": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "output": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              },
              "interruptReason": {
                "type": "string"
              },
              "retryPolicy": {
                "type": "object",
                "properties": {
                  "maxAttempts": {
                    "type": "integer"
                  },
                  "initialBackoffSeconds": {
                    "type": "number"
                  },
                  "backoffMultiplier": {
                    "type": "number"
                  },
                  "maxBackoffSeconds": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "when": {},
              "onTraverse": {},
              "concurrent": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "maxSteps": {
          "type": "integer"
        },
        "stateReducers": {
          "type": "object",
          "additionalProperties": {}
        },
        "state": {
          "type": "object",
          "properties": {
            "schema": {}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false
}
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Samples.Extensions.NodeTrace</RootNamespace>
    <AssemblyName>ext-nodetrace-csharp</AssemblyName>
    <OutputType>Library</OutputType>
    <IsPackable>false</IsPackable>
    <Description>Sample Vais.Agents C# extension: traces per-node timing and demonstrates a node-level cache short-circuit on the graph node seam. Demonstrates host:csharp extension-authored node middleware via GraphNodeMiddleware.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.6" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Samples.Extensions.SessionSummary</RootNamespace>
    <AssemblyName>ext-sessionsum-csharp</AssemblyName>
    <OutputType>Library</OutputType>
    <IsPackable>false</IsPackable>
    <Description>Sample Vais.Agents C# extension: logs session open/close and summarizes the conversation on close via the session lifecycle seam. Demonstrates host:csharp extension-authored session lifecycle handling via SessionLifecycleHook.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.6" />
  </ItemGroup>

</Project>

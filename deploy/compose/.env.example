# .env.example — copy to .env and fill in real values before running the demo stack.
# .env is gitignored; this template is committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   docker compose -f docker-compose.localhost.yml -f docker-compose.demo.yml up -d

# ── LLM API keys ─────────────────────────────────────────────────────────────
# Required by: research-planner (C# plugin), research-agent-live (LangGraph),
#              sgr-analyst (SGR Python plugin), synthesizer (declarative)
OPENAI_API_KEY=sk-...

# Optional. Set when any agent declares `provider: anthropic` and references
# `apiKeyRef: secret://env/ANTHROPIC_API_KEY`. Anthropic does NOT fall back to
# this env var by convention — the apiKeyRef must be explicit in the manifest.
ANTHROPIC_API_KEY=sk-ant-...

# Required by: sgr-analyst (SGR web search via Tavily)
TAVILY_API_KEY=tvly-...

# ── Langfuse observability ────────────────────────────────────────────────────
# Create a project in your local Langfuse UI, then copy the keys here.
# Langfuse UI: http://localhost:3000 (or wherever your Langfuse is running)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Override if Langfuse is not on the default Docker Desktop host port 3000.
# On Linux: replace host.docker.internal with 172.17.0.1 or your bridge IP.
LANGFUSE_HOST=http://host.docker.internal:3000

# Override to change the project name shown in Langfuse traces.
LANGFUSE_PROJECT=vais-agents-demo

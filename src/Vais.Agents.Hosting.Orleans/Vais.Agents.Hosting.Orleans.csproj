<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Hosting.Orleans</RootNamespace>
    <AssemblyName>Vais.Agents.Hosting.Orleans</AssemblyName>
    <Description>Orleans-backed IAgentRuntime + ITaskStore for Vais.Agents. Wraps StatefulAiAgent inside virtual-actor grains with IPersistentState-based history retention; also ships OrleansTaskStore for A2A task persistence across silo restart.</Description>
    <PackageTags>agents;ai;llm;hosting;orleans;actors;a2a</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Core\Vais.Agents.Core.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Eval\Vais.Agents.Eval.csproj" />
    <ProjectReference Include="..\Vais.Agents.Runtime.Plugins\Vais.Agents.Runtime.Plugins.csproj" />
    <ProjectReference Include="..\Vais.Agents.Runtime.Extensions\Vais.Agents.Runtime.Extensions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="A2A" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Orleans.Sdk" />
    <PackageReference Include="Microsoft.Orleans.Runtime" />
    <PackageReference Include="Microsoft.Orleans.Streaming" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais.Agents.Hosting.Orleans.Tests" />
  </ItemGroup>

</Project>

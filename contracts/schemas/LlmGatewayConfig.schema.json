{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vais.agents LlmGatewayConfig manifest",
  "type": "object",
  "properties": {
    "apiVersion": {
      "const": "vais.agents/v1"
    },
    "kind": {
      "const": "LlmGatewayConfig"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "properties": {
        "middleware": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Registered middleware name \u2014 e.g. \u0022Prometheus\u0022, \u0022Fallback\u0022, \u0022ToolRateLimit\u0022."
              },
              "params": {
                "description": "Optional JSON params forwarded to the factory verbatim."
              }
            },
            "additionalProperties": false
          },
          "description": "Ordered list of middleware layers. Execution order: index 0 = outermost interceptor. Each entry is resolved at activation time via ILlmGatewayMiddlewareFactory."
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "requestsPerMinute": {
              "type": "integer",
              "description": "Max completion requests per minute across all agents using this config. Null = uncapped."
            },
            "tokensPerMinute": {
              "type": "integer",
              "description": "Max tokens (prompt \u002B completion) per minute. Null = uncapped."
            }
          },
          "additionalProperties": false,
          "description": "Optional rate-limit caps applied at the gateway level."
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false
}
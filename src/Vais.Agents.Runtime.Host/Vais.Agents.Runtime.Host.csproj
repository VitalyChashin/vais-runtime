<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Runtime.Host</RootNamespace>
    <AssemblyName>Vais.Agents.Runtime.Host</AssemblyName>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <!--
      Runtime product entry point (v0.16 Pillar A). Ships as the container image
      `vais-agents-runtime`, not a published NuGet. Dockerfile lives next to this
      csproj; Helm chart + docker-compose live under deploy/. Composition root
      wires Orleans (localhost OR clustered), durability sidecars in the correct
      order, the HTTP control plane, and optional observability / OPA policy.
    -->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents</RootNamespace>
    <AssemblyName>Vais2.Agents.Abstractions</AssemblyName>
    <Description>Stack-neutral contracts for the Vais2.Agents library. Depends on nothing — not Semantic Kernel, not Microsoft Agent Framework, not Orleans.</Description>
    <PackageTags>agents;ai;llm;abstractions</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

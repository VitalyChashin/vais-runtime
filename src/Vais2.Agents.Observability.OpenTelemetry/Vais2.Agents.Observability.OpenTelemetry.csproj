<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents.Observability.OpenTelemetry</RootNamespace>
    <AssemblyName>Vais2.Agents.Observability.OpenTelemetry</AssemblyName>
    <Description>OpenTelemetry GenAI integration for Vais2.Agents: OpenTelemetryUsageSink (IUsageSink) plus TracerProviderBuilder / MeterProviderBuilder extensions that wire the "Vais2.Agents" ActivitySource and Meter. Follows the OTel GenAI semantic conventions (ADR 0002).</Description>
    <PackageTags>agents;ai;llm;observability;opentelemetry;gen-ai</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais2.Agents.Abstractions\Vais2.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais2.Agents.Core\Vais2.Agents.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

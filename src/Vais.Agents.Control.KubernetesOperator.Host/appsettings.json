{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "KubeOps": "Information",
      "Vais.Agents.Control.Kubernetes": "Information"
    }
  },
  "Vais": {
    "KubernetesOperator": {
      "ControlPlaneBaseUrl": null,
      "ControlPlaneAudience": "vais-agents-runtime",
      "TokenPath": "/var/run/secrets/tokens/vais-runtime-token",
      "AuthMode": "ServiceAccount",
      "WatchNamespaces": null,
      "TokenCacheTtl": "00:05:00",
      "ReconcileBackoffInitial": "00:00:05",
      "ReconcileBackoffMax": "00:15:00"
    }
  },
  "AllowedHosts": "*"
}

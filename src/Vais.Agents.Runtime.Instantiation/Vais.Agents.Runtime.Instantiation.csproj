<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Runtime.Instantiation</RootNamespace>
    <AssemblyName>Vais.Agents.Runtime.Instantiation</AssemblyName>
    <Description>Manifest-driven agent instantiation for Vais.Agents. Translates a stored AgentManifest into a running StatefulAgentOptions via pluggable model-provider factories, guardrail factories, static tools, and MCP/A2A remote refs. v0.17 Pillar B.</Description>
    <PackageTags>agents;ai;llm;manifest;instantiation;vais</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Core\Vais.Agents.Core.csproj" />
    <ProjectReference Include="..\Vais.Agents.Runtime.Plugins\Vais.Agents.Runtime.Plugins.csproj" />
    <ProjectReference Include="..\Vais.Agents.Gateways.McpGovernance\Vais.Agents.Gateways.McpGovernance.csproj" />
    <!-- Plan C1 south cartridge: domain ontology artifact registry, catalog, shaper, and
         call-time middlewares. Required to auto-wire the cartridge into per-agent
         translation when an McpServer manifest carries OntologyRef. -->
    <ProjectReference Include="..\Vais.Agents.Control.Manifests.Json\Vais.Agents.Control.Manifests.Json.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup Label="Model-provider factories (v0.17 Pillar B PR 2).">
    <ProjectReference Include="..\Vais.Agents.Ai.MicrosoftAgentFramework\Vais.Agents.Ai.MicrosoftAgentFramework.csproj" />
    <PackageReference Include="Microsoft.Extensions.AI" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" />
    <PackageReference Include="OpenAI" />
    <PackageReference Include="Azure.AI.OpenAI" />
    <PackageReference Include="Anthropic.SDK" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais.Agents.Runtime.Instantiation.Tests" />
  </ItemGroup>

</Project>

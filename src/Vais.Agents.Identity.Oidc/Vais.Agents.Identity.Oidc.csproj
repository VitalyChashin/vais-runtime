<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Identity.Oidc</RootNamespace>
    <AssemblyName>Vais.Agents.Identity.Oidc</AssemblyName>
    <Description>OIDC identity provider adapter for the Vais.Agents IAgentIdentityProvider contract. Validates inbound JWT Bearer tokens via OIDC discovery + JWKS, and acquires outbound access tokens via the OAuth 2.0 client_credentials grant. Works with any OIDC-compliant IdP (Keycloak, Auth0, Microsoft Entra).</Description>
    <PackageTags>agents;ai;llm;identity;oidc;keycloak;auth0;entra;jwt</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" />
    <PackageReference Include="Microsoft.IdentityModel.Protocols.OpenIdConnect" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais.Agents.Identity.Oidc.Tests" />
  </ItemGroup>

</Project>

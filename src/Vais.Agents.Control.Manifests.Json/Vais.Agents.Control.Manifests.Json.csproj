<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Control.Manifests</RootNamespace>
    <AssemblyName>Vais.Agents.Control.Manifests.Json</AssemblyName>
    <Description>JSON manifest loader + validation core for Vais.Agents. Parses AgentManifest documents from the v0.6 envelope shape (apiVersion / kind / metadata / spec); used natively by the HTTP control plane and delegated-to by the YAML loader.</Description>
    <PackageTags>agents;ai;llm;control-plane;manifest;json</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <!-- Embed the generated base ontology so it is available at runtime without a file-system path. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\contracts\ontology\base-ontology.json"
                      LogicalName="Vais.Agents.Control.Manifests.base-ontology.json" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Persistence.VectorData</RootNamespace>
    <AssemblyName>Vais.Agents.Persistence.VectorData</AssemblyName>
    <Description>RAG building blocks for Vais.Agents: a Microsoft.Extensions.VectorData-backed IKnowledgeRetriever and a retrieval-augmenting IAgentFilter that injects retrieved context into each agent turn's SystemPrompt.</Description>
    <PackageTags>agents;ai;llm;rag;vectordata;retrieval;knowledge</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.VectorData.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

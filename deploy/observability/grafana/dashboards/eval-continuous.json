{
  "title": "Vais — Continuous Eval Scoring",
  "uid": "vais-eval-continuous",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "description": "Live view of continuous production eval scoring. Four metrics from Vais.Agents.Observability.Prometheus.PrometheusContinuousScoringMetricSink drive five panels: pass-rate trend, assertion score distributions, sampled-run count, window coverage, and under-sampling alert.",
  "tags": ["vais", "eval", "continuous", "observability"],
  "templating": {
    "list": [
      {
        "name": "suite_id",
        "type": "query",
        "datasource": { "type": "prometheus" },
        "definition": "label_values(vais_eval_continuous_cases_total, suite_id)",
        "label": "Suite",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pass Rate Over Time",
      "description": "Fraction of sampled production runs that passed all assertions. A drop below the baseline triggers investigation. One series per active continuous suite.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (suite_id) (rate(vais_eval_continuous_cases_total{status=\"Pass\",suite_id=~\"$suite_id\"}[5m])) / sum by (suite_id) (rate(vais_eval_continuous_cases_total{suite_id=~\"$suite_id\"}[5m]))",
          "legendFormat": "{{suite_id}} pass-rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Assertion Score Distribution (p50 / p90)",
      "description": "Median and 90th-percentile assertion scores per kind. Scores are 1.0 for Pass, 0.0 for binary Fail, and continuous [0,1] for JudgeScore. A falling p90 line reveals regressions in partial-credit assertions before the pass-rate collapses.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le, suite_id, kind) (rate(vais_eval_continuous_assertion_score_bucket{suite_id=~\"$suite_id\"}[5m])))",
          "legendFormat": "{{suite_id}} / {{kind}} p50"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.9, sum by (le, suite_id, kind) (rate(vais_eval_continuous_assertion_score_bucket{suite_id=~\"$suite_id\"}[5m])))",
          "legendFormat": "{{suite_id}} / {{kind}} p90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Sampled Runs Per Window",
      "description": "Current count of production runs sampled within the rolling eval window. Tracks whether the sampling rate is delivering enough coverage. Low values may indicate traffic drop or under-sampling.",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "vais_eval_continuous_window_sampled{suite_id=~\"$suite_id\"}",
          "legendFormat": "{{suite_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60 }
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Window Time Remaining (seconds)",
      "description": "Seconds until each suite's current eval window closes and a new one opens. Near-zero means the grain is about to write the window's final row.",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "min by (suite_id) (vais_eval_continuous_window_seconds_remaining{suite_id=~\"$suite_id\"})",
          "legendFormat": "{{suite_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Failed Cases Per Minute",
      "description": "Rate of failed-assertion case results. Spike indicates a regression or judge non-determinism. Correlate with the pass-rate panel to distinguish transient noise from sustained regression.",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (suite_id) (rate(vais_eval_continuous_cases_total{status=\"Fail\",suite_id=~\"$suite_id\"}[5m])) * 60",
          "legendFormat": "{{suite_id}} failures/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ]
}

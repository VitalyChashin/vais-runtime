<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Gateways.Fallback</RootNamespace>
    <AssemblyName>Vais.Agents.Gateways.Fallback</AssemblyName>
    <Description>Provider fallback and load-balancing gateway middleware for Vais.Agents. Retries failed LLM calls across a pool of providers.</Description>
    <PackageTags>agents;ai;llm;fallback;load-balancing;resilience</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

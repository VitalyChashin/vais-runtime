<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Control.Http</RootNamespace>
    <AssemblyName>Vais.Agents.Control.Http.Client</AssemblyName>
    <Description>Typed HTTP client for the Vais.Agents control plane. Mirrors IAgentLifecycleManager verbs; wraps HttpClient so consumers can plug into IHttpClientFactory, retry, and correlation middleware.</Description>
    <PackageTags>agents;ai;llm;control-plane;http;client</PackageTags>
    <!-- RS0027: convenience overloads (manifest, CT=default) intentionally have fewer params than
         full overloads (manifest, idempotencyKey, CT). Both overloads are part of the public API. -->
    <NoWarn>$(NoWarn);RS0027</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Manifests.Json\Vais.Agents.Control.Manifests.Json.csproj" />
    <ProjectReference Include="..\Vais.Agents.Eval\Vais.Agents.Eval.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Net.ServerSentEvents" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais.Agents.Control.Http.Tests" />
  </ItemGroup>

</Project>

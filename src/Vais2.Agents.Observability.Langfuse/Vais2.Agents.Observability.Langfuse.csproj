<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents.Observability.Langfuse</RootNamespace>
    <AssemblyName>Vais2.Agents.Observability.Langfuse</AssemblyName>
    <Description>Langfuse enricher for Vais2.Agents. Ports VAIS2's LangfuseEnrichmentFilter to a stack-neutral IAgentFilter that reads IAgentContextAccessor and tags the active Activity with langfuse.* attributes.</Description>
    <PackageTags>agents;ai;llm;observability;langfuse</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais2.Agents.Abstractions\Vais2.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais2.Agents.Core\Vais2.Agents.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

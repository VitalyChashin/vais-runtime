<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents.Protocols.A2A</RootNamespace>
    <AssemblyName>Vais2.Agents.Protocols.A2A</AssemblyName>
    <Description>Agent-to-Agent (A2A) protocol adapter for Vais2.Agents — surface a remote A2A agent as a local ITool so an agent can delegate sub-tasks to a peer.</Description>
    <PackageTags>agents;ai;llm;a2a;agent-to-agent;tools</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais2.Agents.Abstractions\Vais2.Agents.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="A2A" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais2.Agents.Protocols.A2A.Tests" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Control.Mcp.Server</RootNamespace>
    <AssemblyName>Vais.Agents.Control.Mcp.Server</AssemblyName>
    <Description>Read-only design-tools MCP server for Vais.Agents. Exposes vais.list/get/describe/diff/validate verbs and vais-ontology:// resources so external coding agents can discover and dry-run-validate Vais runtime resources with zero mutation risk.</Description>
    <PackageTags>agents;ai;llm;control-plane;mcp;design-tools;ontology</PackageTags>
    <NoWarn>$(NoWarn);IDE0005</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Abstractions\Vais.Agents.Control.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Control.Manifests.Json\Vais.Agents.Control.Manifests.Json.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\..\contracts\schemas\*.schema.json">
      <LogicalName>Vais.Agents.Control.Mcp.Server.schemas.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JsonSchema.Net" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <PackageReference Include="ModelContextProtocol.Core" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
    <InternalsVisibleTo Include="Vais.Agents.Control.Mcp.Server.Tests" />
  </ItemGroup>

</Project>

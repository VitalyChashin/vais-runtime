<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents.Persistence.Redis</RootNamespace>
    <AssemblyName>Vais2.Agents.Persistence.Redis</AssemblyName>
    <Description>Redis-backed Orleans clustering and grain storage for Vais2.Agents. Thin DI wrappers over Microsoft.Orleans.Clustering.Redis + Microsoft.Orleans.Persistence.Redis that register the AiAgentGrain storage name convention.</Description>
    <PackageTags>agents;ai;llm;hosting;orleans;redis;persistence</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais2.Agents.Hosting.Orleans\Vais2.Agents.Hosting.Orleans.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Orleans.Clustering.Redis" />
    <PackageReference Include="Microsoft.Orleans.Persistence.Redis" />
    <PackageReference Include="StackExchange.Redis" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais.Agents.Runtime.Plugins</RootNamespace>
    <AssemblyName>Vais.Agents.Runtime.Plugins</AssemblyName>
    <Description>Plugin loader for Vais.Agents. Scans a directory of per-plugin subfolders, loads each as its own AssemblyLoadContext with shared-types carve-out, and registers IAgentHandlerFactory implementations with the plugin-handler registry. v0.18 Pillar C.</Description>
    <PackageTags>agents;ai;llm;plugins;runtime;vais</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais.Agents.Abstractions\Vais.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais.Agents.Core\Vais.Agents.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais.Agents.Runtime.Plugins.Tests" />
    <InternalsVisibleTo Include="Vais.Agents.Runtime.Instantiation" />
    <InternalsVisibleTo Include="Vais.Agents.Hosting.Orleans" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Vais2.Agents.Hosting.Orleans</RootNamespace>
    <AssemblyName>Vais2.Agents.Hosting.Orleans</AssemblyName>
    <Description>Orleans-backed IAgentRuntime for Vais2.Agents. Wraps the neutral StatefulAiAgent inside virtual-actor grains with IPersistentState-based history retention and RequestContext-based IAgentContextAccessor.</Description>
    <PackageTags>agents;ai;llm;hosting;orleans;actors</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vais2.Agents.Abstractions\Vais2.Agents.Abstractions.csproj" />
    <ProjectReference Include="..\Vais2.Agents.Core\Vais2.Agents.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Orleans.Sdk" />
    <PackageReference Include="Microsoft.Orleans.Runtime" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Vais2.Agents.Hosting.Orleans.Tests" />
  </ItemGroup>

</Project>

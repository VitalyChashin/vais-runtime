<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Isolate the OSS repo from whatever NuGet sources the developer machine has configured globally.
    Only nuget.org is authoritative here. If you need a private feed (e.g. an internal
    pre-release mirror), add it locally below — don't rely on the machine-wide NuGet.Config.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
